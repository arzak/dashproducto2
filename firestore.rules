rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función reutilizable para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para obtener los datos del usuario actual y validar si es Admin
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Reglas para la colección 'users'
    match /users/{userId} {
      // Cualquiera autenticado puede leer la lista de usuarios (para asignar miembros, ver el directorio)
      allow read: if isAuthenticated();
      
      // La creación está permitida si el usuario está autenticado y su UID coincide (para el registro inicial en AuthContext)
      // o si es un Administrador (agregando desde Team.jsx)
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // La actualización está permitida si es el mismo usuario (editando perfil) o si es Admin (re-asignando roles)
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Solo un admin puede borrar usuarios
      allow delete: if isAdmin();
    }

    // Reglas para la colección 'requirements' (Las tarjetas del Kanban)
    match /requirements/{requirementId} {
      // Todos los usuarios autenticados pueden ver los requerimientos
      allow read: if isAuthenticated();
      
      // Todos los usuarios autenticados pueden crear, editar (mover en Kanban) o borrar requerimientos
      allow write: if isAuthenticated();
    }
    
    // Reglas para la colección 'audit_logs' (historial de ediciones)
    match /audit_logs/{logId} {
      // Cualquier usuario autenticado puede escribir un log de auditoría
      allow create: if isAuthenticated();
      // Solo admins pueden leer el historial completo
      allow read: if isAdmin();
    }
    
    // Regla de seguridad por defecto para bloquear cualquier otra colección no prevista
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
